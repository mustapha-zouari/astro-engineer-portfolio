---
import { siteConfig } from '../data/site';
---

<button aria-label={siteConfig.accessibility.themeToggleLabel} data-theme-toggle>
    <svg width="25px" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <path
            class="sun"
            fill-rule="evenodd"
            d="M12 17.5a5.5 5.5 0 1 0 0-11 5.5 5.5 0 0 0 0 11zm0 1.5a7 7 0 1 0 0-14 7 7 0 0 0 0 14zm12-7a.8.8 0 0 1-.8.8h-2.4a.8.8 0 0 1 0-1.6h2.4a.8.8 0 0 1 .8.8zM4 12a.8.8 0 0 1-.8.8H.8a.8.8 0 0 1 0-1.6h2.5a.8.8 0 0 1 .8.8zm16.5-8.5a.8.8 0 0 1 0 1l-1.8 1.8a.8.8 0 0 1-1-1l1.7-1.8a.8.8 0 0 1 1 0zM6.3 17.7a.8.8 0 0 1 0 1l-1.7 1.8a.8.8 0 1 1-1-1l1.7-1.8a.8.8 0 0 1 1 0zM12 0a.8.8 0 0 1 .8.8v2.5a.8.8 0 0 1-1.6 0V.8A.8.8 0 0 1 12 0zm0 20a.8.8 0 0 1 .8.8v2.4a.8.8 0 0 1-1.6 0v-2.4a.8.8 0 0 1 .8-.8zM3.5 3.5a.8.8 0 0 1 1 0l1.8 1.8a.8.8 0 1 1-1 1L3.5 4.6a.8.8 0 0 1 0-1zm14.2 14.2a.8.8 0 0 1 1 0l1.8 1.7a.8.8 0 0 1-1 1l-1.8-1.7a.8.8 0 0 1 0-1z"
        ></path>
        <path
            class="moon"
            fill-rule="evenodd"
            d="M16.5 6A10.5 10.5 0 0 1 4.7 16.4 8.5 8.5 0 1 0 16.4 4.7l.1 1.3zm-1.7-2a9 9 0 0 1 .2 2 9 9 0 0 1-11 8.8 9.4 9.4 0 0 1-.8-.3c-.4 0-.8.3-.7.7a10 10 0 0 0 .3.8 10 10 0 0 0 9.2 6 10 10 0 0 0 4-19.2 9.7 9.7 0 0 0-.9-.3c-.3-.1-.7.3-.6.7a9 9 0 0 1 .3.8z"
        ></path>
    </svg>
</button>

<script>
    const darkClass = 'dark';
    const noTransitionClass = 'no-transition';

    const toggle = document.querySelector('[data-theme-toggle]');
    const rootEl = document.documentElement;

    type Theme = 'DARK' | 'LIGHT';
    const localStorageUserThemeKey = 'user-theme-preference';

    if (toggle) {
        toggle.addEventListener('click', () => {
            rootEl.classList.add(noTransitionClass);

            rootEl.classList.toggle(darkClass);
            const userTheme: Theme = rootEl.classList.contains(darkClass) ? 'DARK' : 'LIGHT';
            window.localStorage.setItem(localStorageUserThemeKey, userTheme);

            setTimeout(() => {
                rootEl.classList.remove(noTransitionClass);
            }, 50);
        });
    }
</script>

<style>
    button {
        position: fixed;
        bottom: 1rem;
        right: 1rem;
        z-index: 9999;
        cursor: pointer;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        padding: 0;
        background: var(--card-bg);
        border: 2px solid var(--color-border);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 16px var(--color-shadow-lg);
        transition: all var(--transition-speed) ease;
        backdrop-filter: blur(10px);
    }

    button:hover {
        transform: translateY(-4px) scale(1.1);
        box-shadow: 0 8px 24px var(--color-shadow-lg);
        border-color: var(--color-primary);
        background: var(--color-bg-light);
    }

    button:active {
        transform: translateY(-2px) scale(1.05);
    }

    button::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 100%;
        height: 100%;
        border-radius: 50%;
        background: var(--color-primary-light);
        opacity: 0.3;
        transform: translate(-50%, -50%) scale(0);
        transition:
            transform 0.5s ease,
            opacity 0.5s ease;
    }

    button:active::before {
        transform: translate(-50%, -50%) scale(1.5);
        opacity: 1;
        transition:
            transform 0s,
            opacity 0s;
    }

    @keyframes pulse {
        0%,
        100% {
            box-shadow: 0 4px 16px var(--color-shadow-lg);
        }
        50% {
            box-shadow:
                0 4px 16px var(--color-shadow-lg),
                0 0 0 8px rgba(37, 99, 235, 0.1);
        }
    }

    button:hover {
        animation: pulse 2s infinite;
    }

    svg {
        position: relative;
        z-index: 1;
        width: 28px;
        height: 28px;
    }

    .sun {
        fill: transparent;
        transition:
            fill var(--transition-speed) ease,
            transform var(--transition-speed) ease;
    }

    .moon {
        fill: var(--color-secondary);
        transition:
            fill var(--transition-speed) ease,
            transform var(--transition-speed) ease;
    }

    :global(.dark) .sun {
        fill: var(--color-primary);
        animation: rotate 0.5s ease;
    }

    :global(.dark) .moon {
        fill: transparent;
    }

    @keyframes rotate {
        0% {
            transform: rotate(0deg) scale(0.8);
            opacity: 0;
        }
        50% {
            transform: rotate(180deg) scale(1.2);
        }
        100% {
            transform: rotate(360deg) scale(1);
            opacity: 1;
        }
    }

    button:focus {
        outline: 3px solid var(--color-primary);
        outline-offset: 4px;
    }

    button:focus:not(:focus-visible) {
        outline: none;
    }

    @media (max-width: 768px) {
        button {
            bottom: 0.75rem;
            right: 0.75rem;
            width: 48px;
            height: 48px;
        }

        svg {
            width: 24px;
            height: 24px;
        }
    }
</style>
