---
import { siteConfig } from '../data/site';
---

<button aria-label={siteConfig.accessibility.backToTopLabel} class="back-to-top" id="backToTop">
    <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <polyline points="18 15 12 9 6 15"></polyline>
    </svg>
</button>

<script>
    const backToTopButton = document.getElementById('backToTop');

    window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
            backToTopButton?.classList.add('visible');
        } else {
            backToTopButton?.classList.remove('visible');
        }
    });

    backToTopButton?.addEventListener('click', () => {
        window.scrollTo({
            top: 0,
            behavior: 'smooth',
        });
    });
</script>

<style>
    .back-to-top {
        position: fixed;
        bottom: 1rem;
        left: 1rem;
        z-index: 9999;
        cursor: pointer;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        padding: 0;
        background: var(--card-bg);
        border: 2px solid var(--color-border);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 16px var(--color-shadow-lg);
        transition: all var(--transition-speed) ease;
        opacity: 0;
        visibility: hidden;
        transform: translateY(20px);
        backdrop-filter: blur(10px);
    }

    .back-to-top.visible {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    .back-to-top:hover {
        transform: translateY(-4px) scale(1.1);
        box-shadow: 0 8px 24px var(--color-shadow-lg);
        border-color: var(--color-primary);
        background: var(--color-bg-light);
    }

    .back-to-top:active {
        transform: translateY(-2px) scale(1.05);
    }

    .back-to-top::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 100%;
        height: 100%;
        border-radius: 50%;
        background: var(--color-primary-light);
        opacity: 0.3;
        transform: translate(-50%, -50%) scale(0);
        transition:
            transform 0.5s ease,
            opacity 0.5s ease;
    }

    .back-to-top:active::before {
        transform: translate(-50%, -50%) scale(1.5);
        opacity: 1;
        transition:
            transform 0s,
            opacity 0s;
    }

    @keyframes pulse {
        0%,
        100% {
            box-shadow: 0 4px 16px var(--color-shadow-lg);
        }
        50% {
            box-shadow:
                0 4px 16px var(--color-shadow-lg),
                0 0 0 8px rgba(37, 99, 235, 0.1);
        }
    }

    .back-to-top:hover {
        animation: pulse 2s infinite;
    }

    .back-to-top svg {
        position: relative;
        z-index: 1;
        width: 28px;
        height: 28px;
        stroke: var(--color-secondary);
    }

    .back-to-top:focus {
        outline: 3px solid var(--color-primary);
        outline-offset: 4px;
    }

    .back-to-top:focus:not(:focus-visible) {
        outline: none;
    }

    @media (max-width: 768px) {
        .back-to-top {
            bottom: 0.75rem;
            left: 0.75rem;
            width: 48px;
            height: 48px;
        }

        .back-to-top svg {
            width: 24px;
            height: 24px;
        }
    }
</style>
