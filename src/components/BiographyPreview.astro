---
import { homeData } from '../data/home';
import ProfileImage from './ProfileImage.astro';
---

<section class="biography-preview">
    <div class="biography-container">
        <div class="image-wrapper">
            <ProfileImage size="large" />
        </div>
        <div class="content-wrapper">
            <h2>{homeData.biographyPreview.heading}</h2>
            <p class="resume">{homeData.biographyPreview.resume}</p>
            <a href="/biography" class="read-more">
                {homeData.biographyPreview.ctaLabel} →
            </a>
        </div>
    </div>
</section>

<style>
    .biography-preview {
        padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-xxl);
        background: var(--color-bg-gradient);
    }

    .biography-container {
        max-width: var(--max-width-container);
        margin: 0 auto;
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: var(--spacing-xxl);
        background: var(--card-bg);
        border-radius: var(--border-radius-lg);
        padding: var(--spacing-xxl);
        box-shadow: 0 4px 12px var(--card-shadow);
        border: 1px solid var(--card-border);
        align-items: center;
    }

    .image-wrapper {
        position: relative;
    }

    .content-wrapper {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-sm);
    }

    h2 {
        font-size: 2rem;
        color: var(--color-secondary);
        margin-bottom: 0.5rem;
        font-weight: 700;
    }

    .resume {
        font-size: 1.1rem;
        line-height: 1.8;
        color: var(--color-text-light);
        margin: 0;
        text-align: justify;
    }

    .read-more {
        display: inline-block;
        margin-top: var(--spacing-sm);
        color: var(--color-primary);
        font-weight: 600;
        text-decoration: none;
        transition: all var(--transition-speed) ease;
        align-self: flex-start;
    }

    .read-more:hover {
        color: var(--color-primary-dark);
        transform: translateX(5px);
        text-decoration: none;
    }

    @media (max-width: 768px) {
        .biography-preview {
            padding: var(--spacing-md) var(--spacing-sm) var(--spacing-lg);
        }

        .biography-container {
            grid-template-columns: 1fr;
            gap: var(--spacing-md);
            padding: var(--spacing-md);
            text-align: center;
        }

        .resume {
            text-align: left;
            font-size: 1rem;
            line-height: 1.6;
        }

        .read-more {
            align-self: center;
            font-size: 0.95rem;
        }

        h2 {
            font-size: 1.5rem;
            margin-bottom: 0.25rem;
        }
    }
</style>
