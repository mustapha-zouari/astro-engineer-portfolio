---
import { siteConfig } from '../data/site';

interface Props {
    size?: 'small' | 'medium' | 'large';
}

const { size = 'medium' } = Astro.props;
---

<div class={`profile-image-wrapper ${size}`}>
    <div class="open-to-work-frame">
        <img src={siteConfig.profileImage} alt={siteConfig.profileImageAlt} class="profile-image" />
    </div>
    {
        siteConfig.openToWork ? (
            <div class="open-to-work-badge">{siteConfig.openToWorkLabel}</div>
        ) : null
    }
</div>

<style>
    .profile-image-wrapper {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--spacing-sm);
    }

    .profile-image-wrapper.small .open-to-work-frame {
        width: 140px;
        height: 140px;
    }

    .profile-image-wrapper.medium .open-to-work-frame {
        width: 200px;
        height: 200px;
    }

    .profile-image-wrapper.large .open-to-work-frame {
        width: 240px;
        height: 240px;
    }

    .open-to-work-frame {
        position: relative;
        border-radius: 50%;
        padding: 8px;
        background: linear-gradient(
            135deg,
            var(--color-primary) 0%,
            var(--color-accent) 25%,
            var(--color-primary) 50%,
            var(--color-accent) 75%,
            var(--color-primary) 100%
        );
        background-size: 300% 300%;
        animation: gradientRotate 3s ease infinite;
        box-shadow: 0 4px 20px rgba(59, 130, 246, 0.3);
    }

    @keyframes gradientRotate {
        0% {
            background-position: 0% 50%;
        }
        50% {
            background-position: 100% 50%;
        }
        100% {
            background-position: 0% 50%;
        }
    }

    .open-to-work-frame .profile-image {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
        border: 5px solid var(--card-bg);
        outline: none;
        display: block;
        transition: transform var(--transition-speed) ease;
    }

    .open-to-work-frame:hover .profile-image {
        transform: scale(1.05);
    }

    .open-to-work-badge {
        background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
        color: white;
        padding: 0.4rem 1rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        box-shadow: 0 2px 10px rgba(59, 130, 246, 0.3);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
        0%,
        100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.05);
        }
    }

    @media (max-width: 768px) {
        .profile-image-wrapper.small .open-to-work-frame {
            width: 120px;
            height: 120px;
        }

        .profile-image-wrapper.medium .open-to-work-frame {
            width: 160px;
            height: 160px;
        }

        .profile-image-wrapper.large .open-to-work-frame {
            width: 200px;
            height: 200px;
        }

        .open-to-work-badge {
            font-size: 0.75rem;
            padding: 0.35rem 0.8rem;
        }
    }
</style>
